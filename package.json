{
  "name": "union-station",
  "version": "0.1.0",
  "description": "Predictive job scheduler for Web Workers.",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "watch": "npm run build -- --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src test tsdown.config.ts",
    "prepare": "npm run build",
    "test": "npm run build && node --test --test-concurrency=1",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "author": "Michael Bullington",
  "license": "MIT",
  "devDependencies": {
    "oxlint": "^1.61.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbullington/union-station.git"
  },
  "homepage": "https://github.com/mbullington/union-station",
  "bugs": {
    "url": "https://github.com/mbullington/union-station/issues"
  },
  "keywords": [
    "workers",
    "web-workers",
    "scheduler",
    "browser",
    "typescript"
  ]
}
