{
  "name": "union-station",
  "version": "0.1.0",
  "description": "Predictive job scheduler for Web Workers.",
  "main": "dist/index.js",
  "module": "dist/index-esm.js",
  "scripts": {
    "build": "typehead build",
    "watch": "typehead build --watch",
    "serve": "typehead serve",
    "types": "tsc -p tsconfig.types.json",
    "prepare": "npm run types && npm run build",
    "test": "npm run types && npm run build && node --test --test-concurrency=1"
  },
  "author": "Michael Bullington",
  "license": "MIT",
  "devDependencies": {
    "@mapbox/typehead": "^1.2.1",
    "rome": "^11.0.0",
    "typescript": "^4.9.4"
  },
  "type": "commonjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbullington/union-station.git"
  },
  "homepage": "https://github.com/mbullington/union-station",
  "bugs": {
    "url": "https://github.com/mbullington/union-station/issues"
  },
  "keywords": [
    "workers",
    "web-workers",
    "scheduler",
    "browser",
    "typescript"
  ]
}
